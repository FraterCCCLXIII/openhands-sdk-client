# OpenHands Client Configuration
# Copy this file to .env and fill in your values

# ==================== LLM Configuration ====================
# Your LLM API key (required)
LLM_API_KEY=your-api-key-here

# LLM model to use (default: anthropic/claude-sonnet-4-5-20250929)
# For OpenHands Cloud, use: openhands/claude-sonnet-4-5-20250929
LLM_MODEL=anthropic/claude-sonnet-4-5-20250929

# Custom LLM base URL (optional, for custom endpoints)
# LLM_BASE_URL=https://your-custom-endpoint.com/v1

# ==================== Workspace Configuration ====================
# Workspace type: local, docker, remote, api_remote, cloud
WORKSPACE_TYPE=local

# Working directory for local workspace
WORKSPACE_DIR=/workspace

# For remote workspace type
# REMOTE_HOST=https://agent-server.example.com
# REMOTE_API_KEY=your-remote-api-key

# For API remote workspace type
# RUNTIME_API_URL=https://runtime.eval.all-hands.dev
# RUNTIME_API_KEY=your-runtime-api-key

# For OpenHands Cloud workspace type
# OPENHANDS_CLOUD_URL=https://app.all-hands.dev
# OPENHANDS_CLOUD_API_KEY=your-openhands-cloud-api-key

# ==================== Security Configuration ====================
# Security policy: always_confirm, never_confirm, confirm_risky
SECURITY_POLICY=confirm_risky

# ==================== Features ====================
# Enable browser tools (default: false)
ENABLE_BROWSER=false

# Enable metrics tracking (default: true)
ENABLE_METRICS=true

# Max context size for condenser (default: 50)
MAX_CONTEXT_SIZE=50

# ==================== Storage ====================
# Directory for conversation persistence
PERSISTENCE_DIR=./conversations

# ==================== Server ====================
# Server port (default: 12000)
PORT=12000
